# Career AI Platform - Environment Configuration
# Copy this to .env and fill in your values

# --- AI Configuration ---
# Google Gemini API Key (primary AI — fast and generous free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq API Key (fallback AI — ultra-fast inference, free tier)
# Get your free key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI API Key (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# AI Mode: "gemini" (primary), "groq" (fallback), "auto" (detect best)
DEFAULT_MODEL_PROVIDER=gemini

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# --- GitHub (optional) ---
GITHUB_TOKEN=

# --- Cost Control ---
ENABLE_COST_TRACKING=true
MAX_MONTHLY_COST_USD=50.0
