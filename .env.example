# Career AI Platform - Environment Configuration
# Copy this to .env and fill in your values

# --- AI Configuration ---
# OpenAI API Key (optional - leave empty for offline-only mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Ollama Configuration (for local/offline AI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# AI Mode: "auto" (detect best), "online" (force OpenAI), "offline" (force Ollama)
DEFAULT_MODEL_PROVIDER=auto

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# --- GitHub (optional) ---
GITHUB_TOKEN=

# --- Cost Control ---
ENABLE_COST_TRACKING=true
MAX_MONTHLY_COST_USD=50.0
